toggleSyncs["NPCMonster"] = createToggle(espBody, "Monster / Enemy",  "NPCMonster", function(v) if v then ESP:RescanNPCs() end end)
createESPColorRow(espBody, "Monster Color", "NPCMonsterColor", nil)
toggleSyncs["NPCItem"]    = createToggle(espBody, "Items / Objects",   "NPCItem",    function(v) if v then ESP:RescanNPCs() end end)
createESPColorRow(espBody, "Item Color", "NPCItemColor", nil)

