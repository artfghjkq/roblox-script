local cameraHub = Camera:BuildHub(screenGui, Notif, CONFIG, createCorner, toggleSyncs)
toggleSyncs["CameraView"] = function(state)
    CONFIG.CameraView = state
    cameraHub.Visible = state
    if not state then Camera:Stop(); CONFIG.CameraMode = "normal" end
end

