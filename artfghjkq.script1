-- ── TROLL PANEL ─────────────────────────────────────────────
local trollPanel, trollBody = buildPanel("TROLL", 260, 240, UDim2.new(0.5, 80, 0.5, -120))

local scareHub = UI:BuildScareHub(screenGui, Troll, Notif, CONFIG, createCorner, toggleSyncs)

toggleSyncs["Scare"] = createToggle(trollBody, "Scare", "Scare", function(v)
    scareHub.Visible = v
    if v then
        Notif:Send("Scare Hub opened", 2)
        local tgt = Troll:GetTarget()
        if tgt and not Troll:IsSpectating() then
            local ok = Troll:StartSpectate(tgt, Troll:GetSpectateMode())
            if ok then Notif:Send("Auto-spectating " .. tgt.Name, 2) end
        end
    else
        if Troll:IsSpectating() then Troll:StopSpectate() end
    end
end)
toggleSyncs["Fling"]    = createToggle(trollBody, "Fling",      "Fling",    function(v) if v then Troll:StartFling(); Notif:Send("Fling: ON",2) else Troll:StopFling(); Notif:Send("Fling: OFF",2) end end)
toggleSyncs["WalkFling"]= createToggle(trollBody, "Walk Fling", "WalkFling",function(v) if v then Troll:StartWalkFling(); Notif:Send("Walk Fling: ON",2) else Troll:StopWalkFling(); Notif:Send("Walk Fling: OFF",2) end end)
toggleSyncs["AntiFling"]= createToggle(trollBody, "Anti Fling", "AntiFling",function(v) if v then Troll:StartAntiFling(); Notif:Send("Anti Fling: ON",2) else Troll:StopAntiFling(); Notif:Send("Anti Fling: OFF",2) end end)

