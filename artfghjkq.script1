-- ============================================================
-- SAVE / LOAD CONFIG
-- ============================================================
local SAVE_FILE  = "halohalo_config.json"
local COLOR_KEYS = {ESPColor=true, NPCMonsterColor=true, NPCItemColor=true}

local function color3ToTable(c) return {r=c.R, g=c.G, b=c.B} end

local QB_SLOTS = 5
local qbSlots  = {}
local qbBtns   = {}
local qbStrokes  = {}
local qbNameLbls = {}
for i = 1, QB_SLOTS do qbSlots[i] = nil end

local QB_OPTIONS = {
    {label="Speed",   icon="SPD", key="SpeedBoost",    callback=function(v) if not v then local h=player.Character and player.Character:FindFirstChildWhichIsA("Humanoid") if h then h.WalkSpeed=16 end end end},
    {label="Noclip",  icon="NCP", key="Noclip",        callback=nil},
    {label="Invis",   icon="INV", key="Invisibility",   callback=function(v) applyInvisibility(v) end},
    {label="Box ESP", icon="BOX", key="BoxESP",         callback=nil},
    {label="PlrInfo", icon="PLR", key="PlayerInfo",     callback=nil},
    {label="Jump",    icon="JMP", key="SuperJump",      callback=nil},
    {label="King",    icon="KNG", key="KingMode",       callback=nil},
    {label="FPS",     icon="FPS", key="FPSBoost",       callback=function(v) Lighting.GlobalShadows=not v; Lighting.Technology=v and Enum.Technology.Compatibility or Enum.Technology.ShadowMap end},
    {label="Mon ESP", icon="EMN", key="NPCMonster",     callback=function(v) if v then ESP:RescanNPCs() end end},
    {label="AB Mon",  icon="AMN", key="AimbotMonsters", callback=function(v) if v then CONFIG.Aimbot=true; if toggleSyncs["Aimbot"] then toggleSyncs["Aimbot"](true) end; ESP:StartAimbot(CONFIG) end end},
    {label="AB Plr",  icon="APL", key="AimbotPlayers",  callback=function(v) if v then CONFIG.Aimbot=true; if toggleSyncs["Aimbot"] then toggleSyncs["Aimbot"](true) end; ESP:StartAimbot(CONFIG) end end},
}

local function updateQBBtn(i)
    local btn  = qbBtns[i]
    local strk = qbStrokes[i]
    local nlbl = qbNameLbls[i]
    if not btn then return end
    local opt = qbSlots[i]
    if opt then
        local state = CONFIG[opt.key]
        btn.Text             = opt.icon
        btn.TextColor3       = state and BW.ActFg or BW.Dim
        btn.BackgroundColor3 = state and BW.Active or BW.Row
        if strk then strk.Color = state and BW.Active or BW.Border end
        if nlbl then nlbl.Text = opt.label; nlbl.TextColor3 = state and BW.ActFg or BW.Dim end
    else
        btn.Text             = "--"
        btn.TextColor3       = BW.Dim
        btn.BackgroundColor3 = BW.Row
        if strk then strk.Color = BW.Border end
        if nlbl then nlbl.Text = "Empty"; nlbl.TextColor3 = BW.Dim end
    end
end

local function qbSlotsToTable()
    local t = {}
    for i = 1, QB_SLOTS do
        local opt = qbSlots[i]
        t[i] = opt and (opt.key .. "|" .. opt.label) or false
    end
    return t
end

local function saveConfig()
    if not writefile then return end
    pcall(function()
        local data = { config = {}, qbSlots = qbSlotsToTable() }
        for k, v in pairs(CONFIG) do
            data.config[k] = COLOR_KEYS[k] and color3ToTable(v) or v
        end
        local function ser(val)
            local t = type(val)
            if t == "boolean" then return val and "true" or "false"
            elseif t == "number" then return tostring(val)
            elseif t == "string" then return '"' .. val:gsub('"', '\\"') .. '"'
            elseif t == "table" then
                local parts, isArr = {}, (#val > 0)
                for k2, v2 in pairs(val) do
                    parts[#parts+1] = isArr and ser(v2) or ('"'..tostring(k2)..'":' .. ser(v2))
                end
                return isArr and ("["..table.concat(parts,",").."]") or ("{"..table.concat(parts,",").."}")
            else return "null" end
        end
        writefile(SAVE_FILE, ser(data))
    end)
end

local function loadConfig()
    if not (readfile and isfile) then return end
    if not isfile(SAVE_FILE) then return end
    pcall(function()
        local raw = readfile(SAVE_FILE)
        local function parseColor(s)
            local r,g,b = s:match('"r":([%d%.]+).-"g":([%d%.]+).-"b":([%d%.]+)')
            if r then return Color3.new(tonumber(r),tonumber(g),tonumber(b)) end
        end
        for k in pairs(CONFIG) do
            if COLOR_KEYS[k] then
                local block = raw:match('"'..k..'":(%b{})')
                if block then local c=parseColor(block); if c then CONFIG[k]=c end end
            else
                local val = raw:match('"'..k..'":([^,}%]]+)')
                if val then
                    val = val:match("^%s*(.-)%s*$")
                    if val=="true" then CONFIG[k]=true
                    elseif val=="false" then CONFIG[k]=false
                    else local n=tonumber(val); if n then CONFIG[k]=n end end
                end
            end
        end
        local qbBlock = raw:match('"qbSlots":%[(.-)%]')
        if qbBlock then
            local i = 0
            for entry in qbBlock:gmatch('[^,]+') do
                i = i + 1; if i > QB_SLOTS then break end
                entry = entry:match('^%s*"?(.-)\"?%s*$')
                if entry ~= "false" and entry ~= "" then
                    local eKey, eLabel = entry:match("^(.+)|(.+)$")
                    for _, opt in ipairs(QB_OPTIONS) do
                        if eLabel then
                            if opt.key==eKey and opt.label==eLabel then qbSlots[i]=opt; break end
                        else
                            if opt.key==entry then qbSlots[i]=opt; break end
                        end
                    end
                end
            end
        end
        for i2 = 1, QB_SLOTS do updateQBBtn(i2) end
        if CONFIG.Invisibility then applyInvisibility(true) end
        if CONFIG.FPSBoost then
            Lighting.GlobalShadows = false
            Lighting.Technology    = Enum.Technology.Compatibility
        end
    end)
end

-- ============================================================
-- TOGGLE / COLOR ROW BUILDERS
-- ============================================================
local function createToggle(parent, text, key, callback)
    local container = Instance.new("Frame")
    container.Size             = UDim2.new(1, -4, 0, 32)
    container.BackgroundColor3 = BW.Row
    container.Parent           = parent
    createCorner(container, 8)
    createStroke(container, BW.Border, 1)

    local label = Instance.new("TextLabel")
    label.Size               = UDim2.new(1, -50, 1, 0)
    label.Position           = UDim2.new(0, 8, 0, 0)
    label.BackgroundTransparency = 1
    label.Text               = text
    label.Font               = Enum.Font.GothamSemibold
    label.TextSize           = 10
    label.TextColor3         = BW.Text
    label.TextXAlignment     = Enum.TextXAlignment.Left
    label.Parent             = container

    local toggleBtn = Instance.new("Frame")
    toggleBtn.Size             = UDim2.new(0, 34, 0, 17)
    toggleBtn.Position         = UDim2.new(1, -42, 0.5, -8.5)
    toggleBtn.BackgroundColor3 = CONFIG[key] and BW.Active or BW.Border
    toggleBtn.Parent           = container
    createCorner(toggleBtn, 9)

    local indicator = Instance.new("Frame")
    indicator.Size             = UDim2.new(0, 13, 0, 13)
    indicator.Position         = CONFIG[key] and UDim2.new(1,-15,0.5,-6.5) or UDim2.new(0,2,0.5,-6.5)
    indicator.BackgroundColor3 = CONFIG[key] and BW.ActFg or BW.Dim
    indicator.Parent           = toggleBtn
    createCorner(indicator, 7)

    local click = Instance.new("TextButton")
    click.Size               = UDim2.new(1, 0, 1, 0)
    click.BackgroundTransparency = 1
    click.Text               = ""
    click.Parent             = container

    local function updateVisuals(state)
        tween(toggleBtn, {BackgroundColor3 = state and BW.Active or BW.Border}, 0.2)
        tween(indicator, {
            Position         = state and UDim2.new(1,-15,0.5,-6.5) or UDim2.new(0,2,0.5,-6.5),
            BackgroundColor3 = state and BW.ActFg or BW.Dim
        }, 0.2)
    end

    click.MouseButton1Click:Connect(function()
        CONFIG[key] = not CONFIG[key]
        updateVisuals(CONFIG[key])
        if callback then callback(CONFIG[key]) end
        saveConfig()
    end)

    return updateVisuals
end

local function createESPColorRow(parent, text, colorKey, rainbowKey)
    local container = Instance.new("Frame")
    container.Size             = UDim2.new(1, -4, 0, 54)
    container.BackgroundColor3 = BW.Row
    container.Parent           = parent
    createCorner(container, 8)
    createStroke(container, BW.Border, 1)

    local lbl = Instance.new("TextLabel")
    lbl.Size               = UDim2.new(1, -8, 0, 18)
    lbl.Position           = UDim2.new(0, 8, 0, 4)
    lbl.BackgroundTransparency = 1
    lbl.Text               = text
    lbl.Font               = Enum.Font.GothamBold
    lbl.TextSize           = 9
    lbl.TextColor3         = BW.Dim
    lbl.TextXAlignment     = Enum.TextXAlignment.Left
    lbl.Parent             = container

    local div = Instance.new("Frame")
    div.Size             = UDim2.new(1, -16, 0, 1)
    div.Position         = UDim2.new(0, 8, 0, 24)
    div.BackgroundColor3 = BW.Border
    div.Parent           = container

    local idx = 1
    local swatch = Instance.new("Frame")
    swatch.Size             = UDim2.new(0, 16, 0, 16)
    swatch.Position         = UDim2.new(0, 8, 0, 31)
    swatch.BackgroundColor3 = CONFIG[colorKey]
    swatch.Parent           = container
    createCorner(swatch, 4)

    local cName = Instance.new("TextLabel")
    cName.Size               = UDim2.new(0, 55, 0, 16)
    cName.Position           = UDim2.new(0, 28, 0, 31)
    cName.BackgroundTransparency = 1
    cName.Text               = "Custom"
    cName.Font               = Enum.Font.GothamBold
    cName.TextSize           = 9
    cName.TextColor3         = BW.Dim
    cName.TextXAlignment     = Enum.TextXAlignment.Left
    cName.Parent             = container

    local cBtn = Instance.new("TextButton")
    cBtn.Size               = UDim2.new(0, 75, 0, 20)
    cBtn.Position           = UDim2.new(0, 5, 0, 29)
    cBtn.BackgroundTransparency = 1
    cBtn.Text               = ""
    cBtn.Parent             = container
    cBtn.MouseButton1Click:Connect(function()
        idx = (idx % #COLOR_PRESETS) + 1
        local c = COLOR_PRESETS[idx]
        CONFIG[colorKey]        = c.color
        swatch.BackgroundColor3 = c.color
        cName.Text              = c.name
        saveConfig()
    end)

    local rbBtn = Instance.new("TextButton")
    rbBtn.Size     = UDim2.new(0, 70, 0, 18)
    rbBtn.Position = UDim2.new(1, -78, 0, 29)
    rbBtn.Font     = Enum.Font.GothamBold
    rbBtn.TextSize = 7
    rbBtn.Parent   = container
    createCorner(rbBtn, 6)
    if rainbowKey then
        rbBtn.BackgroundColor3 = CONFIG[rainbowKey] and BW.Active or BW.Border
        rbBtn.Text             = "RGB"
        rbBtn.TextColor3       = CONFIG[rainbowKey] and BW.ActFg or BW.Dim
        rbBtn.MouseButton1Click:Connect(function()
            CONFIG[rainbowKey] = not CONFIG[rainbowKey]
            tween(rbBtn, {
                BackgroundColor3 = CONFIG[rainbowKey] and BW.Active or BW.Border,
                TextColor3       = CONFIG[rainbowKey] and BW.ActFg or BW.Dim,
            }, 0.2)
            saveConfig()
        end)
    else
        rbBtn.BackgroundTransparency = 1
        rbBtn.Text                   = ""
    end
end

local function makeDivider(parent, text)
    local div = Instance.new("Frame")
    div.Size                 = UDim2.new(1, -4, 0, 20)
    div.BackgroundTransparency = 1
    div.Parent               = parent
    local l1 = Instance.new("Frame")
    l1.Size             = UDim2.new(0.25, 0, 0, 1)
    l1.Position         = UDim2.new(0, 0, 0.5, 0)
    l1.BackgroundColor3 = BW.Border
    l1.BorderSizePixel  = 0
    l1.Parent           = div
    local lbl = Instance.new("TextLabel")
    lbl.Size               = UDim2.new(0.5, 0, 1, 0)
    lbl.Position           = UDim2.new(0.25, 0, 0, 0)
    lbl.BackgroundTransparency = 1
    lbl.Text               = text
    lbl.Font               = Enum.Font.GothamBold
    lbl.TextSize           = 8
    lbl.TextColor3         = BW.Dim
    lbl.Parent             = div
    local l2 = Instance.new("Frame")
    l2.Size             = UDim2.new(0.25, 0, 0, 1)
    l2.Position         = UDim2.new(0.75, 0, 0.5, 0)
    l2.BackgroundColor3 = BW.Border
    l2.BorderSizePixel  = 0
    l2.Parent           = div
end

-- ============================================================
-- PANEL BUILDER  (reusable floating panel like ScareHub)
-- ============================================================
local openPanels = {}

local function buildPanel(title, w, h, defaultPos)
    local W = w or 260
    local H = h or 360
    local pos = defaultPos or UDim2.new(0.5, -W/2 + 80, 0.5, -H/2)

    local panel = Instance.new("Frame")
    panel.Name             = title .. "Panel"
    panel.Size             = UDim2.new(0, W, 0, H)
    panel.Position         = pos
    panel.BackgroundColor3 = BW.BG
    panel.Active           = true
    panel.Draggable        = true
    panel.Visible          = false
    panel.ZIndex           = 20
    panel.ClipsDescendants = true
    panel.Parent           = screenGui
    createCorner(panel, 12)
    createStroke(panel, BW.Border, 1)

    local topBar = Instance.new("Frame")
    topBar.Size             = UDim2.new(1, 0, 0, 36)
    topBar.BackgroundColor3 = BW.Panel
    topBar.ZIndex           = 21
    topBar.Parent           = panel
    createCorner(topBar, 12)
    local topFill = Instance.new("Frame")
    topFill.Size             = UDim2.new(1, 0, 0.5, 0)
    topFill.Position         = UDim2.new(0, 0, 0.5, 0)
    topFill.BackgroundColor3 = BW.Panel
    topFill.BorderSizePixel  = 0
    topFill.ZIndex           = 21
    topFill.Parent           = topBar

    local titleLbl = Instance.new("TextLabel")
    titleLbl.Size               = UDim2.new(1, -70, 1, 0)
    titleLbl.Position           = UDim2.new(0, 12, 0, 0)
    titleLbl.BackgroundTransparency = 1
    titleLbl.Text               = title
    titleLbl.Font               = Enum.Font.GothamBold
    titleLbl.TextSize           = 12
    titleLbl.TextColor3         = BW.White
    titleLbl.TextXAlignment     = Enum.TextXAlignment.Left
    titleLbl.ZIndex             = 22
    titleLbl.Parent             = topBar

    local minimizeBtn = Instance.new("TextButton")
    minimizeBtn.Size             = UDim2.new(0, 22, 0, 22)
    minimizeBtn.Position         = UDim2.new(1, -50, 0.5, -11)
    minimizeBtn.BackgroundColor3 = BW.Row
    minimizeBtn.Text             = "—"
    minimizeBtn.TextColor3       = BW.Dim
    minimizeBtn.Font             = Enum.Font.GothamBold
    minimizeBtn.TextSize         = 10
    minimizeBtn.ZIndex           = 22
    minimizeBtn.Parent           = topBar
    createCorner(minimizeBtn, 5)
    createStroke(minimizeBtn, BW.Border, 1)

    local closeBtn2 = Instance.new("TextButton")
    closeBtn2.Size             = UDim2.new(0, 22, 0, 22)
    closeBtn2.Position         = UDim2.new(1, -26, 0.5, -11)
    closeBtn2.BackgroundColor3 = BW.Row
    closeBtn2.Text             = "✕"
    closeBtn2.TextColor3       = BW.Dim
    closeBtn2.Font             = Enum.Font.GothamBold
    closeBtn2.TextSize         = 10
    closeBtn2.ZIndex           = 22
    closeBtn2.Parent           = topBar
    createCorner(closeBtn2, 5)
    createStroke(closeBtn2, BW.Border, 1)

    local body = Instance.new("ScrollingFrame")
    body.Size                 = UDim2.new(1, -6, 1, -40)
    body.Position             = UDim2.new(0, 3, 0, 38)
    body.BackgroundTransparency = 1
    body.BorderSizePixel      = 0
    body.ScrollBarThickness   = 2
    body.CanvasSize           = UDim2.new(0, 0, 0, 0)
    body.AutomaticCanvasSize  = Enum.AutomaticSize.Y
    body.ZIndex               = 20
    body.Parent               = panel

    local bodyLayout = Instance.new("UIListLayout", body)
    bodyLayout.SortOrder = Enum.SortOrder.LayoutOrder
    bodyLayout.Padding   = UDim.new(0, 4)
    local bodyPad = Instance.new("UIPadding", body)
    bodyPad.PaddingTop = UDim.new(0, 4); bodyPad.PaddingBottom = UDim.new(0, 6)
    bodyPad.PaddingLeft = UDim.new(0, 4); bodyPad.PaddingRight = UDim.new(0, 4)

    local minimized = false
    local savedH    = H

    minimizeBtn.MouseButton1Click:Connect(function()
        minimized = not minimized
        if minimized then
            savedH = panel.AbsoluteSize.Y
            tween(panel, {Size = UDim2.new(0, W, 0, 36)}, 0.2)
            minimizeBtn.Text = "+"
        else
            tween(panel, {Size = UDim2.new(0, W, 0, savedH)}, 0.25, Enum.EasingStyle.Back)
            minimizeBtn.Text = "—"
        end
    end)

    closeBtn2.MouseButton1Click:Connect(function()
        panel.Visible = false
        if openPanels[title] then
            openPanels[title] = false
        end
    end)

    return panel, body
end

