local cmdRows = {
    {icon="MOV", label="Movement",  desc="Speed · Noclip · Jump · Invisibility", lo=1,
     onTap=function() togglePanel(movPanel, "mov") end},
    {icon="ESP", label="ESP",       desc="Box ESP · Aimbot · Entity · Team Filter", lo=2,
     onTap=function() togglePanel(espPanel, "esp") end},
    {icon="FPS", label="FPS Boost", desc="Boost FPS · Disable Particles", lo=3,
     onTap=function() togglePanel(fpsPanel, "fps") end},
    {icon="SCR", label="Scripts",   desc="Game-specific scripts", lo=4,
     onTap=function() togglePanel(scriptsPanel, "scr") end},
    {icon="TRL", label="Troll",     desc="Scare · Fling · Anti Fling", lo=5,
     onTap=function() togglePanel(trollPanel, "trl") end},
    {icon="SPC", label="Spectate",  desc="Spectate players", lo=6,
     onTap=function() togglePanel(specPanel, "spc") end},
    {icon="CAM", label="Camera",    desc="Third person view", lo=7,
     onTap=function()
         CONFIG.CameraView = not CONFIG.CameraView
         cameraHub.Visible = CONFIG.CameraView
         if not CONFIG.CameraView then Camera:Stop(); CONFIG.CameraMode = "normal" end
         Notif:Send(CONFIG.CameraView and "Camera Hub opened" or "Camera View OFF", 2)
     end},
}

for _, cmd in ipairs(cmdRows) do
    makeCommandRow(cmd.icon, cmd.label, cmd.desc, cmd.lo, cmd.onTap)
end

-- ============================================================
-- QUICK BUTTONS
-- ============================================================
local qbToggleBtn = Instance.new("TextButton")
qbToggleBtn.Size             = UDim2.new(0, 32, 0, 32)
qbToggleBtn.Position         = UDim2.new(0, 20, 0.5, -90)
qbToggleBtn.BackgroundColor3 = BW.Panel
qbToggleBtn.Text             = "QB"
qbToggleBtn.TextColor3       = BW.Text
qbToggleBtn.Font             = Enum.Font.GothamBold
qbToggleBtn.TextSize         = 11
qbToggleBtn.Active           = true
qbToggleBtn.Draggable        = true
qbToggleBtn.ZIndex           = 5
qbToggleBtn.Parent           = screenGui
createCorner(qbToggleBtn, 8)
createStroke(qbToggleBtn, BW.Border, 1)

local qbContainer = Instance.new("Frame")
qbContainer.Size                 = UDim2.new(0, 180, 0, 10)
qbContainer.BackgroundTransparency = 1
qbContainer.Active               = false
qbContainer.Visible              = false
qbContainer.ZIndex               = 5
qbContainer.Parent               = screenGui

local qbGrid = Instance.new("UIGridLayout", qbContainer)
qbGrid.CellSize            = UDim2.new(0, 54, 0, 54)
qbGrid.CellPadding         = UDim2.new(0, 6, 0, 6)
qbGrid.SortOrder           = Enum.SortOrder.LayoutOrder
qbGrid.FillDirection       = Enum.FillDirection.Horizontal
qbGrid.HorizontalAlignment = Enum.HorizontalAlignment.Left

local qbPanel = Instance.new("Frame")
qbPanel.Size             = UDim2.new(0, 200, 0, 10)
qbPanel.BackgroundColor3 = BW.Panel
qbPanel.Visible          = false
qbPanel.ZIndex           = 10
qbPanel.Parent           = screenGui
createCorner(qbPanel, 10)
createStroke(qbPanel, BW.Border, 1)

local function syncQBPositions()
    local ap   = qbToggleBtn.AbsolutePosition
    local rows = math.ceil(QB_SLOTS / 3)
    local cols = math.min(QB_SLOTS, 3)
    qbContainer.Position = UDim2.new(0, ap.X, 0, ap.Y + 38)
    qbContainer.Size     = UDim2.new(0, cols*54+(cols-1)*6, 0, rows*54+(rows-1)*6)
end
qbToggleBtn:GetPropertyChangedSignal("AbsolutePosition"):Connect(syncQBPositions)

local qbPanelLayout = Instance.new("UIListLayout", qbPanel)
qbPanelLayout.SortOrder = Enum.SortOrder.LayoutOrder
qbPanelLayout.Padding   = UDim.new(0, 3)
local qbPanelPad = Instance.new("UIPadding", qbPanel)
qbPanelPad.PaddingTop = UDim.new(0,6); qbPanelPad.PaddingBottom = UDim.new(0,6)
qbPanelPad.PaddingLeft = UDim.new(0,6); qbPanelPad.PaddingRight = UDim.new(0,6)

local qbPanelTitle = Instance.new("TextLabel")
qbPanelTitle.Size               = UDim2.new(1, 0, 0, 20)
qbPanelTitle.BackgroundTransparency = 1
qbPanelTitle.Text               = "Assign Quick Button"
qbPanelTitle.Font               = Enum.Font.GothamBold
qbPanelTitle.TextSize           = 10
qbPanelTitle.TextColor3         = BW.Text
qbPanelTitle.TextXAlignment     = Enum.TextXAlignment.Left
qbPanelTitle.ZIndex             = 10
qbPanelTitle.Parent             = qbPanel

local qbPanelClose = Instance.new("TextButton")
qbPanelClose.Size               = UDim2.new(0, 18, 0, 18)
qbPanelClose.Position           = UDim2.new(1, -24, 0, 1)
qbPanelClose.BackgroundTransparency = 1
qbPanelClose.Text               = "X"
qbPanelClose.TextColor3         = BW.Dim
qbPanelClose.Font               = Enum.Font.GothamBold
qbPanelClose.TextSize           = 14
qbPanelClose.ZIndex             = 10
qbPanelClose.Parent             = qbPanel

local currentEditSlot = nil
local qbOptionRows    = {}

local function refreshAssignedLabels()
    for _, r in ipairs(qbOptionRows) do r.label.Text = "" end
    for i, slotOpt in ipairs(qbSlots) do
        if slotOpt then
            for _, r in ipairs(qbOptionRows) do
                if r.opt.key == slotOpt.key and r.opt.label == slotOpt.label then
                    r.label.Text = "Slot " .. i
                end
            end
        end
    end
end

for _, opt in ipairs(QB_OPTIONS) do
    local capOpt = opt
    local row = Instance.new("TextButton")
    row.Size             = UDim2.new(1, 0, 0, 26)
    row.BackgroundColor3 = BW.Row
    row.Text             = "[" .. opt.icon .. "]  " .. opt.label
    row.TextColor3       = BW.Text
    row.Font             = Enum.Font.GothamSemibold
    row.TextSize         = 10
    row.TextXAlignment   = Enum.TextXAlignment.Left
    row.ZIndex           = 10
    row.Parent           = qbPanel
    createCorner(row, 6)
    local rPad = Instance.new("UIPadding", row); rPad.PaddingLeft = UDim.new(0, 8)
    local assignedLbl = Instance.new("TextLabel")
    assignedLbl.Size               = UDim2.new(0, 50, 1, 0)
    assignedLbl.Position           = UDim2.new(1, -55, 0, 0)
    assignedLbl.BackgroundTransparency = 1
    assignedLbl.Text               = ""
    assignedLbl.Font               = Enum.Font.GothamBold
    assignedLbl.TextSize           = 8
    assignedLbl.TextColor3         = BW.Dim
    assignedLbl.ZIndex             = 10
    assignedLbl.Parent             = row
    table.insert(qbOptionRows, {row=row, opt=capOpt, label=assignedLbl})
    row.MouseButton1Click:Connect(function()
        if not currentEditSlot then return end
        for i, s in ipairs(qbSlots) do
            if s and s.key==capOpt.key and s.label==capOpt.label then
                qbSlots[i]=nil; updateQBBtn(i)
            end
        end
        qbSlots[currentEditSlot] = capOpt
        updateQBBtn(currentEditSlot)
        refreshAssignedLabels()
        qbPanel.Visible = false; currentEditSlot = nil
        saveConfig()
    end)
end

local clearRow = Instance.new("TextButton")
clearRow.Size             = UDim2.new(1, 0, 0, 26)
clearRow.BackgroundColor3 = Color3.fromRGB(30, 10, 10)
clearRow.Text             = "[ X ]  Clear Slot"
clearRow.TextColor3       = BW.Red
clearRow.Font             = Enum.Font.GothamBold
clearRow.TextSize         = 10
clearRow.TextXAlignment   = Enum.TextXAlignment.Left
clearRow.ZIndex           = 10
clearRow.Parent           = qbPanel
createCorner(clearRow, 6)
local clPad = Instance.new("UIPadding", clearRow); clPad.PaddingLeft = UDim.new(0, 8)
clearRow.MouseButton1Click:Connect(function()
    if not currentEditSlot then return end
    qbSlots[currentEditSlot] = nil; updateQBBtn(currentEditSlot)
    refreshAssignedLabels(); qbPanel.Visible = false; currentEditSlot = nil; saveConfig()
end)

qbPanelClose.MouseButton1Click:Connect(function() qbPanel.Visible = false; currentEditSlot = nil end)
qbPanelLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
    qbPanel.Size = UDim2.new(0, 200, 0, qbPanelLayout.AbsoluteContentSize.Y + 12)
end)

for slotIdx = 1, QB_SLOTS do
    local btn = Instance.new("TextButton")
    btn.Size             = UDim2.new(0, 54, 0, 54)
    btn.BackgroundColor3 = BW.Row
    btn.Text             = "--"
    btn.TextColor3       = BW.Dim
    btn.Font             = Enum.Font.GothamBold
    btn.TextSize         = 11
    btn.Active           = true
    btn.ZIndex           = 5
    btn.LayoutOrder      = slotIdx
    btn.Parent           = qbContainer
    createCorner(btn, 10)
    local strk = createStroke(btn, BW.Border, 1)
    qbStrokes[slotIdx] = strk
    local nlbl = Instance.new("TextLabel")
    nlbl.Size             = UDim2.new(1, 0, 0, 12)
    nlbl.Position         = UDim2.new(0, 0, 1, 2)
    nlbl.BackgroundTransparency = 1
    nlbl.Text             = "Empty"
    nlbl.Font             = Enum.Font.GothamBold
    nlbl.TextSize         = 7
    nlbl.TextColor3       = BW.Dim
    nlbl.ZIndex           = 5
    nlbl.Parent           = btn
    qbNameLbls[slotIdx]  = nlbl
    qbBtns[slotIdx]      = btn

    local holdConn = nil; local isHolding = false
    local function openPanel(si)
        currentEditSlot = si
        local ap = qbToggleBtn.AbsolutePosition
        qbPanel.Position = UDim2.new(0, ap.X + 200, 0, ap.Y)
        qbPanel.Visible  = true
        refreshAssignedLabels()
    end
    btn.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            isHolding = false
            holdConn = task.delay(0.4, function() isHolding = true; openPanel(slotIdx) end)
        end
    end)
    btn.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            if holdConn then task.cancel(holdConn); holdConn = nil end
            if not isHolding then
                local opt = qbSlots[slotIdx]
                if opt then
                    CONFIG[opt.key] = not CONFIG[opt.key]
                    if opt.callback then opt.callback(CONFIG[opt.key]) end
                    if toggleSyncs[opt.key] then toggleSyncs[opt.key](CONFIG[opt.key]) end
                    updateQBBtn(slotIdx)
                    Notif:Send((CONFIG[opt.key] and "ON" or "OFF") .. ": " .. opt.label, 2)
                else
                    openPanel(slotIdx)
                end
            end
        end
    end)
end

local qbOpen = false
qbToggleBtn.MouseButton1Click:Connect(function()
    qbOpen = not qbOpen
    qbContainer.Visible = qbOpen
    if not qbOpen then qbPanel.Visible = false end
    tween(qbToggleBtn, {BackgroundColor3 = qbOpen and BW.Active or BW.Panel}, 0.2)
end)
syncQBPositions()

-- ============================================================
-- AIMBOT LOCK FLOAT BUTTON
-- ============================================================
local lockFloatBtn = Instance.new("TextButton")
lockFloatBtn.Size             = UDim2.new(0, 54, 0, 54)
lockFloatBtn.BackgroundColor3 = BW.Panel
lockFloatBtn.Text             = "LOCK"
lockFloatBtn.TextColor3       = BW.Dim
lockFloatBtn.Font             = Enum.Font.GothamBold
lockFloatBtn.TextSize         = 9
lockFloatBtn.Active           = true
lockFloatBtn.Draggable        = true
lockFloatBtn.Visible          = false
lockFloatBtn.ZIndex           = 6
lockFloatBtn.Parent           = screenGui
createCorner(lockFloatBtn, 10)
local lockFloatStroke = createStroke(lockFloatBtn, BW.Border, 1)

local lockNameLbl = Instance.new("TextLabel")
lockNameLbl.Size               = UDim2.new(1, 2, 0, 12)
lockNameLbl.Position           = UDim2.new(-0.02, 0, 1, 2)
lockNameLbl.BackgroundTransparency = 1
lockNameLbl.Text               = ""
lockNameLbl.Font               = Enum.Font.GothamBold
lockNameLbl.TextSize           = 7
lockNameLbl.TextColor3         = BW.Dim
lockNameLbl.ZIndex             = 6
lockNameLbl.Parent             = lockFloatBtn

local function syncLockBtnPos()
    local ap = qbToggleBtn.AbsolutePosition
    lockFloatBtn.Position = UDim2.new(0, ap.X + 42, 0, ap.Y)
end
qbToggleBtn:GetPropertyChangedSignal("AbsolutePosition"):Connect(syncLockBtnPos)
syncLockBtnPos()

lockFloatBtn.MouseButton1Click:Connect(function()
    if ESP:IsAimbotLocked() then
        ESP:SetAimbotLocked(false); Notif:Send("Aim lock: OFF", 1)
    else
        local part = ESP:GetLockedPart()
        if part and part.Parent then
            ESP:SetAimbotLocked(true); Notif:Send("Locked: " .. part.Parent.Name, 2)
        else
            Notif:Send("No target yet!", 2)
        end
    end
end)

RunService.Heartbeat:Connect(function()
    local aimbotOn = CONFIG.Aimbot and (CONFIG.AimbotPlayers or CONFIG.AimbotMonsters)
    lockFloatBtn.Visible = aimbotOn
    if not aimbotOn then return end
    if ESP:IsAimbotLocked() then
        local part = ESP:GetLockedPart()
        lockFloatBtn.BackgroundColor3 = BW.Active
        lockFloatBtn.TextColor3       = BW.ActFg
        lockFloatStroke.Color         = Color3.fromRGB(220, 50, 50)
        lockFloatStroke.Thickness     = 2
        lockNameLbl.Text              = (part and part.Parent and part.Parent.Name) or "Lost"
        lockNameLbl.TextColor3        = Color3.fromRGB(220, 50, 50)
    else
        local part = ESP:GetLockedPart()
        local name = (part and part.Parent and part.Parent.Name) or ""
        lockFloatBtn.BackgroundColor3 = BW.Panel
        lockFloatBtn.TextColor3       = BW.Dim
        lockFloatStroke.Color         = BW.Border
        lockFloatStroke.Thickness     = 1
        lockNameLbl.Text              = name ~= "" and name or "tap to lock"
        lockNameLbl.TextColor3        = BW.Dim
    end
end)

-- ============================================================
-- LOAD CONFIG + SYNC VISUALS
-- ============================================================
loadConfig()
for key, updateFn in pairs(toggleSyncs) do
    if CONFIG[key] ~= nil then updateFn(CONFIG[key]) end
end
for _, refreshFn in pairs(sliderSyncs) do refreshFn() end

if CONFIG.DisableParticles then
    for _, v in pairs(workspace:GetDescendants()) do
        if v:IsA("ParticleEmitter") or v:IsA("Smoke") or v:IsA("Fire") or v:IsA("Sparkles") then
            v.Enabled = false
        end
    end
end

-- ============================================================
-- RUNTIME
-- ============================================================
local menuOpen = false
iconBtn.MouseButton1Click:Connect(function()
    menuOpen = not menuOpen
    mainFrame.Visible = menuOpen
    if menuOpen then
        mainFrame.Size = UDim2.new(0, 0, 0, 0)
        tween(mainFrame, {Size = UDim2.new(0, FRAME_W, 0, FRAME_H)}, 0.4, Enum.EasingStyle.Back)
    end
end)

closeBtn.MouseButton1Click:Connect(function()
    menuOpen = false; mainFrame.Visible = false
end)

RunService.Heartbeat:Connect(function()
    pcall(function()
        local char = player.Character
        local hum  = char and char:FindFirstChildWhichIsA("Humanoid")
        if hum then
            if CONFIG.SpeedBoost then hum.WalkSpeed  = CONFIG.WalkSpeed end
            if CONFIG.KingMode   then hum.Health = hum.MaxHealth; hum.MaxHealth = 999999 end
        end
        if CONFIG.Noclip and char then
            for _, part in pairs(char:GetDescendants()) do
                if part:IsA("BasePart") and part.CanCollide then part.CanCollide = false end
            end
        end
        for i = 1, QB_SLOTS do updateQBBtn(i) end
        ESP:Update(CONFIG, COLORS, rainbowHue)
    end)
end)

UserInputService.JumpRequest:Connect(function()
    if CONFIG.SuperJump then
        pcall(function()
            local char = player.Character
            local hrp  = char:FindFirstChild("HumanoidRootPart")
            if hrp then hrp.Velocity = Vector3.new(hrp.Velocity.X, CONFIG.JumpPower, hrp.Velocity.Z) end
        end)
    end
end)

local function onCharacterAdded(newChar)
    task.wait(1)
    if CONFIG.Invisibility then Invi:OnCharacterAdded(newChar) end
    newChar.ChildAdded:Connect(function()
        if CONFIG.Invisibility then Invi:OnCharacterAdded(newChar) end
    end)
end

player.CharacterAdded:Connect(onCharacterAdded)
if player.Character then onCharacterAdded(player.Character) end

Notif:Send("HALO-HALO v0.1.3 loaded.", 4)
