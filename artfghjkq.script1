-- ── MOVEMENT PANEL ──────────────────────────────────────────
local movPanel, movBody = buildPanel("MOVEMENT", 260, 340, UDim2.new(0.5, 80, 0.5, -170))

toggleSyncs["SpeedBoost"] = createToggle(movBody, "Speed Boost", "SpeedBoost", function(v)
    if not v then
        local hum = player.Character and player.Character:FindFirstChildWhichIsA("Humanoid")
        if hum then hum.WalkSpeed = 16 end
    end
end)

do
    local row = Instance.new("Frame")
    row.Size             = UDim2.new(1, -4, 0, 32)
    row.BackgroundColor3 = BW.Row
    row.Parent           = movBody
    createCorner(row, 8); createStroke(row, BW.Border, 1)
    local lbl = Instance.new("TextLabel")
    lbl.Size = UDim2.new(1,-80,1,0); lbl.Position = UDim2.new(0,8,0,0)
    lbl.BackgroundTransparency = 1; lbl.Text = "Walk Speed"
    lbl.Font = Enum.Font.GothamSemibold; lbl.TextSize = 10
    lbl.TextColor3 = BW.Text; lbl.TextXAlignment = Enum.TextXAlignment.Left; lbl.Parent = row
    local box = Instance.new("TextBox")
    box.Size = UDim2.new(0,64,0,22); box.Position = UDim2.new(1,-70,0.5,-11)
    box.BackgroundColor3 = BW.Panel; box.Text = tostring(CONFIG.WalkSpeed)
    box.Font = Enum.Font.GothamBold; box.TextSize = 11; box.TextColor3 = BW.White
    box.ClearTextOnFocus = false; box.TextXAlignment = Enum.TextXAlignment.Center; box.Parent = row
    createCorner(box, 5); createStroke(box, BW.Border, 1)
    box.FocusLost:Connect(function()
        local v = tonumber(box.Text)
        if v and v >= 1 and v <= 1000 then CONFIG.WalkSpeed = math.floor(v); saveConfig()
        else box.Text = tostring(CONFIG.WalkSpeed) end
    end)
end

toggleSyncs["Noclip"]      = createToggle(movBody, "Noclip",      "Noclip")
toggleSyncs["SuperJump"]   = createToggle(movBody, "Super Jump",  "SuperJump")

do
    local row = Instance.new("Frame")
    row.Size = UDim2.new(1,-4,0,32); row.BackgroundColor3 = BW.Row; row.Parent = movBody
    createCorner(row, 8); createStroke(row, BW.Border, 1)
    local lbl = Instance.new("TextLabel")
    lbl.Size = UDim2.new(1,-80,1,0); lbl.Position = UDim2.new(0,8,0,0)
    lbl.BackgroundTransparency = 1; lbl.Text = "Jump Power"
    lbl.Font = Enum.Font.GothamSemibold; lbl.TextSize = 10
    lbl.TextColor3 = BW.Text; lbl.TextXAlignment = Enum.TextXAlignment.Left; lbl.Parent = row
    local box = Instance.new("TextBox")
    box.Size = UDim2.new(0,64,0,22); box.Position = UDim2.new(1,-70,0.5,-11)
    box.BackgroundColor3 = BW.Panel; box.Text = tostring(CONFIG.JumpPower)
    box.Font = Enum.Font.GothamBold; box.TextSize = 11; box.TextColor3 = BW.White
    box.ClearTextOnFocus = false; box.TextXAlignment = Enum.TextXAlignment.Center; box.Parent = row
    createCorner(box, 5); createStroke(box, BW.Border, 1)
    box.FocusLost:Connect(function()
        local v = tonumber(box.Text)
        if v and v >= 1 and v <= 5000 then CONFIG.JumpPower = math.floor(v); saveConfig()
        else box.Text = tostring(CONFIG.JumpPower) end
    end)
end

toggleSyncs["KingMode"]    = createToggle(movBody, "King Mode",   "KingMode")
toggleSyncs["Invisibility"]= createToggle(movBody, "Invisibility","Invisibility", function(v) applyInvisibility(v) end)

-- ── ESP PANEL ───────────────────────────────────────────────
local espPanel, espBody = buildPanel("ESP", 260, 400, UDim2.new(0.5, 80, 0.5, -200))

toggleSyncs["BoxESP"]     = createToggle(espBody, "Box ESP",     "BoxESP")
createESPColorRow(espBody, "Box Color", "ESPColor", "BoxRainbow")
toggleSyncs["PlayerInfo"] = createToggle(espBody, "Player Info", "PlayerInfo")
toggleSyncs["TeamFilter"] = createToggle(espBody, "Team Filter", "TeamFilter", function(v)
    if v then
        CONFIG.PlayerInfo = true
        if toggleSyncs["PlayerInfo"] then toggleSyncs["PlayerInfo"](true) end
        ESP:RescanNPCs()
        Notif:Send("Team Filter ON - Player Info auto-enabled", 2)
    end
    saveConfig()
end)

makeDivider(espBody, "AIMBOT")

toggleSyncs["Aimbot"] = createToggle(espBody, "Aimbot", "Aimbot", function(v)
    if v then ESP:StartAimbot(CONFIG) else ESP:StopAimbot() end
end)

do
    local row = Instance.new("Frame")
    row.Size = UDim2.new(1,-4,0,30); row.BackgroundColor3 = BW.Row; row.Parent = espBody
    createCorner(row, 8); createStroke(row, BW.Border, 1)
    local lbl = Instance.new("TextLabel")
    lbl.Size = UDim2.new(0.45,0,1,0); lbl.Position = UDim2.new(0,8,0,0)
    lbl.BackgroundTransparency = 1; lbl.Text = "Target"
    lbl.Font = Enum.Font.GothamSemibold; lbl.TextSize = 10
    lbl.TextColor3 = BW.Text; lbl.TextXAlignment = Enum.TextXAlignment.Left; lbl.Parent = row
    local headBtn = Instance.new("TextButton")
    headBtn.Size = UDim2.new(0,60,0,20); headBtn.Position = UDim2.new(1,-132,0.5,-10)
    headBtn.BackgroundColor3 = CONFIG.AimbotTarget=="head" and BW.Active or BW.Panel
    headBtn.Text = "HEAD"; headBtn.TextColor3 = CONFIG.AimbotTarget=="head" and BW.ActFg or BW.Dim
    headBtn.Font = Enum.Font.GothamBold; headBtn.TextSize = 9; headBtn.Parent = row
    createCorner(headBtn, 5)
    local bodyBtn2 = Instance.new("TextButton")
    bodyBtn2.Size = UDim2.new(0,60,0,20); bodyBtn2.Position = UDim2.new(1,-68,0.5,-10)
    bodyBtn2.BackgroundColor3 = CONFIG.AimbotTarget=="body" and BW.Active or BW.Panel
    bodyBtn2.Text = "BODY"; bodyBtn2.TextColor3 = CONFIG.AimbotTarget=="body" and BW.ActFg or BW.Dim
    bodyBtn2.Font = Enum.Font.GothamBold; bodyBtn2.TextSize = 9; bodyBtn2.Parent = row
    createCorner(bodyBtn2, 5)
    local function updateAB()
        headBtn.BackgroundColor3  = CONFIG.AimbotTarget=="head" and BW.Active or BW.Panel
        headBtn.TextColor3        = CONFIG.AimbotTarget=="head" and BW.ActFg or BW.Dim
        bodyBtn2.BackgroundColor3 = CONFIG.AimbotTarget=="body" and BW.Active or BW.Panel
        bodyBtn2.TextColor3       = CONFIG.AimbotTarget=="body" and BW.ActFg or BW.Dim
    end
    headBtn.MouseButton1Click:Connect(function()  CONFIG.AimbotTarget="head"; updateAB(); saveConfig() end)
    bodyBtn2.MouseButton1Click:Connect(function() CONFIG.AimbotTarget="body"; updateAB(); saveConfig() end)
end

toggleSyncs["AimbotPlayers"]  = createToggle(espBody, "Aim at Players",  "AimbotPlayers")
toggleSyncs["AimbotMonsters"] = createToggle(espBody, "Aim at Monsters", "AimbotMonsters")

